<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="rptRujukanMasuk" pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <parameter name="namars" class="java.lang.String"/>
    <parameter name="alamatrs" class="java.lang.String"/>
    <parameter name="kotars" class="java.lang.String"/>
    <parameter name="propinsirs" class="java.lang.String"/>
    <parameter name="kontakrs" class="java.lang.String"/>
    <parameter name="emailrs" class="java.lang.String"/>
    <parameter name="periode" class="java.lang.String"/>
    <parameter name="logo" class="java.io.InputStream"/>
    <parameter name="tanggal" class="java.util.Date"/>

    <queryString><![CDATA[]]></queryString>

    <field name="temp1" class="java.lang.String"/>
    <field name="temp2" class="java.lang.String"/>
    <field name="temp3" class="java.lang.String"/>
    <field name="temp4" class="java.lang.String"/>
    <field name="temp5" class="java.lang.String"/>

    <background><band/></background>

    <title>
        <band height="105">
            <image scaleImage="FillFrame" onErrorType="Blank">
                <reportElement x="0" y="2" width="48" height="45"/>
                <imageExpression class="java.io.InputStream"><![CDATA[$P{logo}]]></imageExpression>
            </image>
            <image scaleImage="RetainShape" onErrorType="Blank">
                <reportElement x="754" y="2" width="48" height="45"/>
                <imageExpression><![CDATA[new java.io.FileInputStream("./report/logo2.jpg")]]></imageExpression>
            </image>
            <textField isBlankWhenNull="true">
                <reportElement x="50" y="0" width="702" height="17"/>
                <textElement textAlignment="Center"><font fontName="Tahoma" size="12" isBold="true"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$P{namars}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="50" y="18" width="702" height="13"/>
                <textElement textAlignment="Center"><font fontName="Tahoma" size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$P{alamatrs}+", "+$P{kotars}+", "+$P{propinsirs}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="50" y="31" width="702" height="13"/>
                <textElement textAlignment="Center"><font fontName="Tahoma" size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$P{kontakrs}+" | "+$P{emailrs}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="48" width="802" height="1"/>
                <graphicElement><pen lineWidth="1.5"/></graphicElement>
            </line>
            <staticText>
                <reportElement x="0" y="52" width="802" height="16"/>
                <textElement textAlignment="Center"><font fontName="Tahoma" size="11" isBold="true"/></textElement>
                <text><![CDATA[LAPORAN RUJUKAN MASUK PER WILAYAH]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="68" width="802" height="13"/>
                <textElement textAlignment="Center"><font fontName="Tahoma" size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA["Periode : "+$P{periode}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="83" width="802" height="1"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>
            <!-- Header kolom -->
            <staticText>
                <reportElement mode="Opaque" x="0" y="86" width="30" height="16" backcolor="#D5E8D4"/>
                <textElement verticalAlignment="Middle"><font fontName="Tahoma" size="8" isBold="true"/></textElement>
                <text><![CDATA[ No.]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="30" y="86" width="190" height="16" backcolor="#D5E8D4"/>
                <textElement verticalAlignment="Middle"><font fontName="Tahoma" size="8" isBold="true"/></textElement>
                <text><![CDATA[ Faskes Perujuk]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="220" y="86" width="120" height="16" backcolor="#D5E8D4"/>
                <textElement verticalAlignment="Middle"><font fontName="Tahoma" size="8" isBold="true"/></textElement>
                <text><![CDATA[ Poli Rujukan]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="340" y="86" width="380" height="16" backcolor="#D5E8D4"/>
                <textElement verticalAlignment="Middle"><font fontName="Tahoma" size="8" isBold="true"/></textElement>
                <text><![CDATA[ Penyakit]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="720" y="86" width="82" height="16" backcolor="#D5E8D4"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="Tahoma" size="8" isBold="true"/></textElement>
                <text><![CDATA[Jumlah]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="102" width="802" height="1"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>
        </band>
    </title>

    <detail>
        <band height="15">
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement stretchType="RelativeToBandHeight" x="0" y="0" width="30" height="14"/>
                <textElement><font fontName="Tahoma" size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{temp1}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement stretchType="RelativeToBandHeight" x="30" y="0" width="190" height="14"/>
                <textElement><font fontName="Tahoma" size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{temp2}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement stretchType="RelativeToBandHeight" x="220" y="0" width="120" height="14"/>
                <textElement><font fontName="Tahoma" size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{temp3}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement stretchType="RelativeToBandHeight" x="340" y="0" width="380" height="14"/>
                <textElement><font fontName="Tahoma" size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{temp4}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement stretchType="RelativeToBandHeight" x="720" y="0" width="82" height="14"/>
                <textElement textAlignment="Center"><font fontName="Tahoma" size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{temp5}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement positionType="FixRelativeToBottom" x="0" y="14" width="802" height="1"/>
                <graphicElement><pen lineWidth="0.25" lineColor="#CCCCCC"/></graphicElement>
            </line>
        </band>
    </detail>

    <pageFooter>
        <band height="18">
            <line>
                <reportElement x="0" y="0" width="802" height="1"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </line>
            <textField pattern="dd/MM/yyyy HH.mm.ss" isBlankWhenNull="true">
                <reportElement x="0" y="3" width="100" height="13"/>
                <textElement><font fontName="Tahoma" size="7"/></textElement>
                <textFieldExpression class="java.util.Date"><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
            <textField pattern="" isBlankWhenNull="true">
                <reportElement x="560" y="3" width="170" height="13"/>
                <textElement textAlignment="Right"><font fontName="Tahoma" size="7"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA["Halaman " + $V{PAGE_NUMBER} + " dari "]]></textFieldExpression>
            </textField>
            <textField evaluationTime="Report" isBlankWhenNull="true">
                <reportElement x="730" y="3" width="30" height="13"/>
                <textElement><font fontName="Tahoma" size="7"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA["" + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>

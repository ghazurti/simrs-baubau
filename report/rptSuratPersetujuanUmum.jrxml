					<font fontName="Tahoma" size="8" isBold="true"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[PERNYATAAN]]></text>
			</staticText>
			<staticText>
				<reportElement x="20" y="552" width="522" height="30" uuid="24950a7d-9de0-42d3-9168-bacb535f52ec"/>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Dengan menandatangani format ini, saya telah membaca, memahami dan sepenuhnya setuju dengan setiap pernyataan yang terdapat pada Persetujuan Umum/General Consent ini serta tanpa paksaan dari pihak manapun dengan penuh kesadaran.]]></text>
			</staticText>

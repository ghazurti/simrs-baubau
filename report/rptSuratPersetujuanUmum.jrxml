			<staticText>
				<reportElement x="20" y="326" width="13" height="10" uuid="0b3a0d30-1b7d-4eb0-b2b9-eeec448b5c47">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[c.]]></text>
			</staticText>
			<staticText>
				<reportElement x="33" y="326" width="509" height="10" uuid="8d0f8810-ec63-4c4a-b0fe-dbc2e5e30139"/>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Saya telah menerima informasi tentang peraturan yang diberlakukan oleh rumah sakit dan saya beserta keluarga bersedia untuk mematuhinya, termasuk akan mematuhi jam berkunjung pasien sesuai dengan aturan di rumah sakit, penunggu pasien bersedia untuk selalu memakai tanda pengenal khusus yang diberikan oleh rumah sakit.]]></text>
			</staticText>
			<staticText>
				<reportElement x="5" y="250" width="14" height="10" uuid="f6f33571-df5c-4eb3-ad0d-8d6a35e2a16a">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="true"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[II.]]></text>
			</staticText>
			<staticText>
				<reportElement x="20" y="302" width="13" height="10" uuid="c1a7578c-53a1-418b-a0ed-65a8a7304a22">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[b.]]></text>
			</staticText>
			<staticText>
				<reportElement x="33" y="261" width="509" height="39" uuid="a1f150b7-7f84-45f6-be38-2e1bd8887a6e">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Saya memahami informasi yang ada di dalam diri Saya, termasuk diagnosis, hasil laboratorium dan hasil tes diagnostik yang akan digunakan untuk perawatan medis, RSUD Kota Baubau akan menjamin kerahasiaannya. Saya memberi wewenang kepada rumah sakit untuk memberikan informasi tentang diagnosis, hasil pelayanan dan pengobatan bila diperlukan untuk memproses klaim asuransi/perusahaan dan atau lembaga pemerintah.]]></text>
			</staticText>
			<staticText>
				<reportElement x="20" y="250" width="522" height="10" uuid="94506005-be76-4943-be17-2db188ab8412">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="true"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[PERSETUJUAN PELEPASAN INFORMASI]]></text>
			</staticText>
			<staticText>
				<reportElement x="20" y="261" width="13" height="10" uuid="29484366-66be-41a0-8eb4-5fde9093abe9">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[a.]]></text>
			</staticText>
			<staticText>
				<reportElement x="33" y="302" width="509" height="22" uuid="fb8eca4d-5b51-4e79-a237-5e036b02cd9f"/>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Saya memberi wewenang kepada rumah sakit untuk memberikan informasi tentang diagnosis, hasil pelayanan dan pengobatan termasuk situasi tertentu (contoh: keadaan kritis atau terkait penyakit menular) Saya kepada anggota keluarga saya.]]></text>
			</staticText>
			<staticText>
				<reportElement x="34" y="355" width="508" height="22" uuid="40d16363-85bb-4ba0-a88e-cac00b7a315a">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Saya memiliki hak yang sama untuk memperoleh akses informasi kesehatan saya dan mengambil bagian dalam keputusan mengenai penyakit saya serta dalam hal perawatan medis dan rencana pengobatan. Saya telah mendapat informasi tentang "Hak dan Kewajiban Pasien" di RSUD Kota Baubau melalui penjelasan petugas, leaflet, dan banner yang telah tersedia.]]></text>
			</staticText>
			<line>
				<reportElement x="0" y="341" width="545" height="1" uuid="e227ca5b-5937-42a8-b66f-2a2cb618af3e"/>
				<graphicElement>
					<pen lineWidth="0.5" lineStyle="Solid"/>
				</graphicElement>
			</line>
			<textField>
				<reportElement x="34" y="379" width="508" height="22" uuid="591fe812-4ce0-4032-8baf-dcd75971fb4a"/>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Saya memahami bahwa "+$P{namars}+" tidak bertanggung jawab atas kehilangan barang-barang pribadi dan barang berharga yang dibawa ke rumah sakit. Saya telah mendapatkan informasi mengenai proses untuk menyampaikan keluhan dan proses yang harus dilakukan pada saat terjadi konflik/perbedaan pendapat dalam proses perawatan saya."]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="6" y="344" width="14" height="10" uuid="74ab20e4-e748-496d-80a9-2f2893803dc1">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="true"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[III.]]></text>
			</staticText>
			<staticText>
				<reportElement x="21" y="379" width="13" height="10" uuid="81e25913-5500-4b9c-b579-7723cd90112e">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[•]]></text>
			</staticText>
			<staticText>
				<reportElement x="21" y="344" width="521" height="10" uuid="9eb270c4-a8f7-49c9-8a9e-21c8d36bbeea">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="true"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[HAK DAN KEWAJIBAN PASIEN]]></text>
			</staticText>
			<staticText>
				<reportElement x="21" y="355" width="13" height="10" uuid="5cb71ad3-6f3a-4f00-9dc3-d23cbc3c7695">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>

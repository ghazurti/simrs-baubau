				</textElement>
				<text><![CDATA[•]]></text>
			</staticText>
			<line>
				<reportElement x="0" y="201" width="545" height="1" uuid="6d2b0787-3d6d-4631-bb7c-0358a6b3074f"/>
				<graphicElement>
					<pen lineWidth="0.5" lineStyle="Solid"/>
				</graphicElement>
			</line>
			<staticText>
				<reportElement x="5" y="406" width="14" height="10" uuid="0f3b1d84-0f82-4762-ac44-7a2e42cf4012">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="true"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[IV.]]></text>
			</staticText>
			<staticText>
				<reportElement x="20" y="417" width="522" height="29" uuid="47ebd238-8f85-4dd1-bf9f-a194cde62695">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Saya tidak diperkenankan untuk membawa barang-barang berharga ke ruang rawat jalan/gawat darurat. Barang berharga harus diamankan oleh keluarga atau teman, jika tidak ada keluarga atau teman, maka dititipkan di tempat yang telah disiapkan oleh rumah sakit.]]></text>
			</staticText>
			<staticText>
				<reportElement x="20" y="406" width="522" height="10" uuid="fdd8b81b-8d7f-417c-a3b3-95802c9cb67c">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="true"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[INFORMASI RAWAT JALAN DAN GAWAT DARURAT]]></text>
			</staticText>
			<line>
				<reportElement x="0" y="403" width="545" height="1" uuid="9d25dfc0-8f79-4c0a-a60b-192c2efd6f3b"/>
				<graphicElement>
					<pen lineWidth="0.5" lineStyle="Solid"/>
				</graphicElement>
			</line>
			<textField>
				<reportElement x="20" y="462" width="522" height="22" uuid="c541ed95-09d2-4547-9915-e91ed8e01eef">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="8" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Saya mengizinkan / tidak mengizinkan* "+$P{namars}+" memberi akses bagi keluarga dan handai taulan serta orang-orang yang akan menengok saya (sebutkan nama, bila ada permintaan khusus yang tidak diizinkan) :"]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="5" y="451" width="14" height="10" uuid="fa1d42db-e613-469b-a2bd-ff7b5951939a">

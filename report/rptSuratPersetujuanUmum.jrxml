				<reportElement x="0" y="584" width="545" height="1" uuid="d70d8e3b-63bb-4d59-8f2c-d0f6d708a17b"/>
				<graphicElement>
					<pen lineWidth="0.5" lineStyle="Solid"/>
				</graphicElement>
			</line>
			<line>
				<reportElement x="0" y="817" width="545" height="1" uuid="c50f37a1-7222-40bd-bd7a-c14693e15b20"/>
				<graphicElement>
					<pen lineWidth="0.5" lineStyle="Solid"/>
				</graphicElement>
			</line>
			<textField isStretchWithOverflow="true">
				<reportElement x="33" y="500" width="509" height="24" uuid="4088afbc-ee4a-43ed-ab89-15f5de849e7c">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<box>
					<pen lineStyle="Double"/>
					<topPen lineWidth="0.0" lineStyle="Double"/>
					<leftPen lineWidth="0.0" lineStyle="Double"/>
					<bottomPen lineWidth="0.0" lineStyle="Double"/>
